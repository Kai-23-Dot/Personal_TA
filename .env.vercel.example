# ==================================================================
# Conlearn — Vercel environment variables
# Paste into Vercel: Project → Settings → Environment Variables → Import .env
# Fill in the values on the right of each = sign. Delete any optional
# integration blocks you are not using.
# ==================================================================

# ---- REQUIRED: Supabase (Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- REQUIRED: AI (chat, quizzes, flashcards, summaries, vision) ----
OPENAI_API_KEY=sk-your-openai-key

# ---- REQUIRED: Public base URL (OAuth + Stripe redirects) ----
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ---- REQUIRED for billing: Stripe ----
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ---- RECOMMENDED: Embeddings for RAG / search (fallback is poor without it) ----
VOYAGE_API_KEY=pa-your-voyage-key

# ---- RECOMMENDED: Audio note transcription (only if users upload audio) ----
SARVAM_API_KEY=your-sarvam-key

# ---- OPTIONAL: Canvas LMS OAuth ----
CANVAS_CLIENT_ID=your-canvas-client-id
CANVAS_CLIENT_SECRET=your-canvas-client-secret

# ---- OPTIONAL: Google Classroom OAuth + Drive ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# ---- OPTIONAL: Microsoft Teams Education OAuth ----
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=common

# ---- OPTIONAL: Infinite Campus ----
INFINITE_CAMPUS_CLIENT_ID=your-ic-client-id
INFINITE_CAMPUS_CLIENT_SECRET=your-ic-client-secret

# ---- OPTIONAL: Which OAuth buttons show on login/signup (e.g. google,microsoft) ----
NEXT_PUBLIC_OAUTH_PROVIDERS=google

# ---- OPTIONAL: Secures the /api/sync cron endpoint (if using Vercel Cron) ----
CRON_SECRET=a-random-secret-string
