{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Chrome (click element → open in VS Code)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*"
      }
    }
  ]
}
