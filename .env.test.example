# E2E test credentials — copy to .env.test (gitignored) and fill in.
# Tests run against the live Supabase project: groups created by tests are
# prefixed "e2e-" and deleted in cleanup.
E2E_EMAIL=you@example.com
E2E_PASSWORD=your-password

# Optional second account: enables the two-user join + non-owner-403 tests
# (skipped when unset).
# E2E_EMAIL_2=
# E2E_PASSWORD_2=

# Optional override; defaults to the Playwright-managed dev server on :3100.
# PLAYWRIGHT_BASE_URL=
