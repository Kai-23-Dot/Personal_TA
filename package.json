{
  "name": "conlearn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next .next-dev .next-build",
    "clean:dev": "rm -rf .next .next-dev",
    "clean:build": "rm -rf .next-build",
    "dev": "node scripts/dev-server.mjs",
    "prebuild": "npm run clean:build",
    "build": "env -u __NEXT_PRIVATE_STANDALONE_CONFIG -u __NEXT_PRIVATE_ORIGIN NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
