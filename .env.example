# ============================================================
# PersonalTA.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase ----
# Found at: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-only. Never expose to client.

# ---- Sarvam AI (AI — chat, quiz, summarization, OCR, audio transcription) ----
# Get your key from: https://app.sarvam.ai
# Model used: sarvam-30b
# Audio transcription uses Sarvam Saaras v3 ASR
# To change the model, edit lib/ai/provider.ts
SARVAM_API_KEY=your-sarvam-api-key

# ---- Voyage AI (Embeddings for RAG) ----
# Get from: https://dash.voyageai.com/
# If not set, a zero-vector placeholder is used in development.
VOYAGE_API_KEY=pa-...

# ---- Google OAuth (Classroom + Drive) ----
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/lms/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ---- Canvas LMS OAuth ----
# Each school must issue a Developer Key. Contact your school's Canvas admin.
# Redirect URI: https://your-domain.com/api/lms/canvas
CANVAS_CLIENT_ID=your-canvas-client-id
CANVAS_CLIENT_SECRET=your-canvas-client-secret

# ---- Microsoft Azure (Teams Education + OneDrive) ----
# Register at: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: https://your-domain.com/api/lms/microsoft
# Grant API permissions: EduAssignments.ReadBasic, EduRoster.ReadBasic, Calendars.Read
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=common   # or your tenant ID for school-specific AAD

# ---- App ----
# Your deployed URL (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://your-app.vercel.app in production

# ---- Cron job security (for /api/sync cron) ----
CRON_SECRET=a-random-secret-string-for-cron-authorization

# ---- Stripe (subscriptions / billing) ----
# Get keys from: https://dashboard.stripe.com → Developers → API keys
# Create a $20/mo recurring Product + Price, then paste its price ID below.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
# Webhook signing secret from `stripe listen` (dev) or the Dashboard webhook endpoint (prod).
# Endpoint URL: https://your-domain.com/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
